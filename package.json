{
  "name": "stremini-desktop",
  "version": "3.0.0",
  "description": "Stremini Desktop — AI Overlay",
  "main": "src/main.js",
  "author": "Stremini",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "ai.stremini.desktop",
    "productName": "Stremini",
    "directories": { "output": "dist" },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": { "oneClick": true, "perMachine": false },
    "files": ["src/**/*", "assets/**/*", "package.json"]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "playwright": "^1.40.0"
  }
}
